# Terraflow Studio — environment variables
# Fill in your values below and restart the server.

# ── CouchDB ───────────────────────────────────────────────────────────────────
COUCHDB_USER=admin
COUCHDB_PASSWORD=changeme
COUCHDB_DB=terraflow_studio_configs

# ── LLM Provider ──────────────────────────────────────────────────────────────
# STEP 1: Set the provider  →  anthropic | openai | gemini | ollama
LLM_PROVIDER=gemini

# STEP 2: Paste your API key (not needed for ollama)
LLM_API_KEY=

# STEP 3: Set the model (leave blank for provider default)
#   anthropic → claude-3-5-haiku-20241022  |  openai → gpt-4o-mini
#   gemini    → gemini-1.5-flash           |  ollama → llama3.2
LLM_MODEL=gemini-1.5-flash

# STEP 4: Base URL — only needed for non-default endpoints
#   Groq (openai-compat): https://api.groq.com/openai/v1
#   Vertex AI (gemini):   https://us-central1-aiplatform.googleapis.com/v1/projects/MY_PROJECT/locations/us-central1/publishers/google/models
#   Ollama:               http://localhost:11434/api/chat
LLM_BASE_URL=

# ── LLM tuning ────────────────────────────────────────────────────────────────
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.2
LLM_TIMEOUT=60

# ── TF CLI (terraform fmt / validate) ────────────────────────────────────────
# Full path to terraform/tofu binary — only needed if not already in system PATH.
# Example (Windows): TERRAFORM_PATH=C:\terraform\terraform.exe
# Example (macOS/Linux): TERRAFORM_PATH=/usr/local/bin/terraform
TERRAFORM_PATH=C:\terraform_1.14.9\terraform.exe
OPENTOFU_PATH=

# ── GitHub Integration ────────────────────────────────────────────────────────
# Generate token at: https://github.com/settings/tokens  (needs repo scope)
GITHUB_TOKEN=
GITHUB_REPO=
GITHUB_BRANCH=main
GITHUB_BASE_PATH=terraform
