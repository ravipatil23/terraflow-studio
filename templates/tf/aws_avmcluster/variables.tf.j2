# modules/{{ module_name }}/variables.tf

variable "display_name" {
  description = "Display name for the Autonomous VM Cluster."
  type    = string
  default = "{{ display_name }}"
}

variable "autonomous_data_storage_size_in_tbs" {
  description = "Data storage size allocated for Autonomous Databases, in TBs."
  type    = number
  default = {{ autonomous_data_storage_size_in_tbs }}
}

variable "cpu_core_count_per_node" {
  description = "Number of CPU cores enabled per node."
  type    = number
  default = {{ cpu_core_count_per_node }}
}

variable "memory_per_oracle_compute_unit_in_gbs" {
  description = "Memory allocated per Oracle Compute Unit, in GBs."
  type    = number
  default = {{ memory_per_oracle_compute_unit_in_gbs }}
}

variable "total_container_databases" {
  description = "Total number of Autonomous Container Databases that can be created."
  type    = number
  default = {{ total_container_databases }}
}

variable "scan_listener_port_non_tls" {
  description = "SCAN listener port for non-TLS (TCP). Default 1521."
  type    = number
  default = {{ scan_listener_port_non_tls }}
}

variable "scan_listener_port_tls" {
  description = "SCAN listener port for TLS (TCP). Default 2484."
  type    = number
  default = {{ scan_listener_port_tls }}
}

variable "license_model" {
  description = "Oracle license model."
  type    = string
  default = "{{ license_model }}"
}

variable "is_mtls_enabled_vm_cluster" {
  description = "Enable mutual TLS (mTLS) authentication."
  type    = bool
  default = {{ is_mtls_enabled_vm_cluster }}
}

# ── Infrastructure references ──────────────────────────────────────────────────
# ID pair (required) — auto-wired from module outputs in root main.tf:
#   cloud_exadata_infrastructure_id = module.{{ mn1 }}.infra_id
#   odb_network_id                  = module.{{ mn0 }}.network_id
variable "cloud_exadata_infrastructure_id" {
  description = "Exadata Infrastructure ID (required) — auto-wired from module.{{ mn1 }}.infra_id in root."
  type    = string
  default = "{{ cloud_exadata_infrastructure_id }}"
}

variable "odb_network_id" {
  description = "ODB Network ID (required) — auto-wired from module.{{ mn0 }}.network_id in root."
  type    = string
  default = "{{ odb_network_id }}"
}

# ARN pair (optional) — used when resources are in a different account or stack
#   cloud_exadata_infrastructure_arn = module.{{ mn1 }}.infra_arn
#   odb_network_arn                  = module.{{ mn0 }}.network_arn
variable "cloud_exadata_infrastructure_arn" {
  description = "Exadata Infrastructure ARN (optional) — for cross-account references."
  type    = string
  default = "{{ cloud_exadata_infrastructure_arn }}"
}

variable "odb_network_arn" {
  description = "ODB Network ARN (optional) — for cross-account references."
  type    = string
  default = "{{ odb_network_arn }}"
}

variable "db_servers" {
  description = "List of DB server IDs to use for this cluster."
  type        = list(string)
  default     = [{{ db_servers | map("tojson") | join(", ") }}]
}

variable "description" {
  description = "User-provided description."
  type    = string
  default = "{{ description }}"
}

variable "time_zone" {
  description = "Time zone for the Autonomous VM cluster."
  type    = string
  default = "{{ time_zone }}"
}

variable "maintenance_window" {
  description = "Maintenance window configuration."
  type = object({
    preference                       = string
    patching_mode                    = string
    is_custom_action_timeout_enabled = bool
    custom_action_timeout_in_mins    = number
    days_of_week       = optional(set(object({ name = string })))
    hours_of_day       = optional(set(number))
    lead_time_in_weeks = optional(number)
    months             = optional(set(object({ name = string })))
    weeks_of_month     = optional(set(number))
  })
  default = {
    preference                       = "{{ mw_preference }}"
    patching_mode                    = "{{ mw_patching_mode }}"
    is_custom_action_timeout_enabled = {{ mw_is_custom_action_timeout_enabled }}
    custom_action_timeout_in_mins    = {{ mw_custom_action_timeout_mins }}
    days_of_week       = null
    hours_of_day       = null
    lead_time_in_weeks = null
    months             = null
    weeks_of_month     = null
  }
}

variable "tags" {
  description = "Tags to assign to the resource."
  type    = map(string)
  default = {
{% for k, v in tags.items() %}
    "{{ k }}" = "{{ v }}"
{% else %}
    "ManagedBy" = "Terraform"
{% endfor %}
  }
}
