# main.tf — Generated by Terraflow Studio
# Root module — wires all ODB@AWS modules.
# Toolchain: {{ 'OpenTofu' if iac_tool == 'opentofu' else 'Terraform' }}

terraform {
  required_version = "{{ '>= 1.6.0' if iac_tool == 'opentofu' else '>= 1.5.0' }}"
  required_providers {
    aws = {
{% if iac_tool == 'opentofu' %}
      # OpenTofu resolves hashicorp/aws from registry.opentofu.org by default
{% endif %}
      source  = "hashicorp/aws"
      version = ">= 6.15.0"
    }
{% if oci_databases %}
    oci = {
      source  = "oracle/oci"
      version = ">= 6.0.0"
    }
{% endif %}
  }
}

provider "aws" {
  region = var.aws_region
}

{% if oci_databases %}
# ── OCI Provider (DB Home / CDB / PDB) ───────────────────────────────────────
# Set these env vars or use a ~/.oci/config profile:
#   export TF_VAR_oci_tenancy_ocid=ocid1.tenancy...
#   export TF_VAR_oci_user_ocid=ocid1.user...
#   export TF_VAR_oci_fingerprint=xx:xx:xx:...
provider "oci" {
  auth             = var.oci_auth_method
  region           = var.oci_region
  tenancy_ocid     = var.oci_auth_method == "APIKey" ? var.oci_tenancy_ocid    : null
  user_ocid        = var.oci_auth_method == "APIKey" ? var.oci_user_ocid       : null
  fingerprint      = var.oci_auth_method == "APIKey" ? var.oci_fingerprint     : null
  private_key_path = var.oci_auth_method == "APIKey" ? var.oci_private_key_path : null
}
variable "oci_auth_method"      { type = string; default = "APIKey" }
variable "oci_region"           { type = string; default = "{{ oci_region }}" }
variable "oci_tenancy_ocid"     { type = string; default = ""; sensitive = true }
variable "oci_user_ocid"        { type = string; default = ""; sensitive = true }
variable "oci_fingerprint"      { type = string; default = ""; sensitive = true }
variable "oci_private_key_path" { type = string; default = "~/.oci/oci_api_key.pem" }
{% endif %}

{% for net in networks %}
# ── ODB Network: {{ net.module_name }} ──────────────────────────────────────────
module "{{ net.module_name }}" {
  source = "./modules/{{ net.module_name }}"

  display_name         = var.{{ net.module_name }}_display_name
  availability_zone_id = var.{{ net.module_name }}_availability_zone_id
  client_subnet_cidr   = var.{{ net.module_name }}_client_subnet_cidr
  backup_subnet_cidr   = var.{{ net.module_name }}_backup_subnet_cidr
  s3_access            = var.{{ net.module_name }}_s3_access
  zero_etl_access      = var.{{ net.module_name }}_zero_etl_access
  tags                 = var.tags
}

{% endfor %}
{% for inf in infras %}
# ── Exadata Infrastructure: {{ inf.module_name }} ──────────────────────────────
module "{{ inf.module_name }}" {
  source = "./modules/{{ inf.module_name }}"

  display_name         = var.{{ inf.module_name }}_display_name
  shape                = var.{{ inf.module_name }}_shape
  compute_count        = var.{{ inf.module_name }}_compute_count
  storage_count        = var.{{ inf.module_name }}_storage_count
  availability_zone_id = var.{{ inf.module_name }}_availability_zone_id
  tags                 = var.tags
}

{% endfor %}
{% for peer in peerings %}
# ── Network Peering: {{ peer.module_name }} ────────────────────────────────────
module "{{ peer.module_name }}" {
  source = "./modules/{{ peer.module_name }}"

  display_name    = var.{{ peer.module_name }}_display_name
  odb_network_id  = module.{{ peer.network_ref }}.network_id
  peer_network_id = var.{{ peer.module_name }}_peer_network_id
  tags            = var.tags

  depends_on = [module.{{ peer.network_ref }}]
}

{% endfor %}
{% for cl in clusters %}
# ── VM Cluster: {{ cl.module_name }} ──────────────────────────────────────────
module "{{ cl.module_name }}" {
  source = "./modules/{{ cl.module_name }}"

  display_name                    = var.{{ cl.module_name }}_display_name
  cpu_core_count                  = var.{{ cl.module_name }}_cpu_core_count
  gi_version                      = var.{{ cl.module_name }}_gi_version
  hostname_prefix                 = var.{{ cl.module_name }}_hostname_prefix
  license_model                   = var.{{ cl.module_name }}_license_model
{% if cl.vm_mode == 'id' %}
  cloud_exadata_infrastructure_id = module.{{ cl.infra_ref }}.infra_id
  odb_network_id                  = module.{{ cl.network_ref }}.network_id
{% else %}
  cloud_exadata_infrastructure_arn = module.{{ cl.infra_ref }}.infra_arn
  odb_network_arn                  = module.{{ cl.network_ref }}.network_arn
{% endif %}
  ssh_public_keys                 = var.{{ cl.module_name }}_ssh_public_keys
  db_servers                      = var.{{ cl.module_name }}_db_servers
  tags                            = var.tags

  depends_on = [module.{{ cl.infra_ref }}, module.{{ cl.network_ref }}]
}

{% endfor %}
{% for av in avmclusters %}
# ── Autonomous VM Cluster: {{ av.module_name }} ───────────────────────────────
module "{{ av.module_name }}" {
  source = "./modules/{{ av.module_name }}"

  display_name                          = var.{{ av.module_name }}_display_name
  autonomous_data_storage_size_in_tbs   = var.{{ av.module_name }}_autonomous_data_storage_size_in_tbs
  cpu_core_count_per_node               = var.{{ av.module_name }}_cpu_core_count_per_node
  memory_per_oracle_compute_unit_in_gbs = var.{{ av.module_name }}_memory_per_oracle_compute_unit_in_gbs
  total_container_databases             = var.{{ av.module_name }}_total_container_databases
  scan_listener_port_non_tls            = var.{{ av.module_name }}_scan_listener_port_non_tls
  scan_listener_port_tls                = var.{{ av.module_name }}_scan_listener_port_tls
  license_model                         = var.{{ av.module_name }}_license_model
  is_mtls_enabled_vm_cluster            = var.{{ av.module_name }}_is_mtls_enabled_vm_cluster
  cloud_exadata_infrastructure_id       = module.{{ av.infra_ref }}.infra_id
  odb_network_id                        = module.{{ av.network_ref }}.network_id
  cloud_exadata_infrastructure_arn      = module.{{ av.infra_ref }}.infra_arn
  odb_network_arn                       = module.{{ av.network_ref }}.network_arn
  db_servers                            = var.{{ av.module_name }}_db_servers
  tags                                  = var.tags

  depends_on = [module.{{ av.infra_ref }}, module.{{ av.network_ref }}]
}

{% endfor %}
{% for db in oci_databases %}
# ── OCI DB: {{ db.module_name }} — Step 1: DB Home ───────────────────────────
module "{{ db.module_name }}_dbhome" {
  source          = "./modules/{{ db.module_name }}_dbhome"
  vm_cluster_ocid = module.{{ db.vmcluster_ref }}.ocid
  display_name    = var.{{ db.module_name }}_db_home_display_name
  db_version      = var.{{ db.module_name }}_db_version
  depends_on      = [module.{{ db.vmcluster_ref }}]
}

# ── OCI DB: {{ db.module_name }} — Step 2: CDB ───────────────────────────────
module "{{ db.module_name }}_cdb" {
  source         = "./modules/{{ db.module_name }}_cdb"
  db_home_id     = module.{{ db.module_name }}_dbhome.db_home_id
  db_name        = var.{{ db.module_name }}_db_name
  admin_password = var.{{ db.module_name }}_admin_password
  character_set  = var.{{ db.module_name }}_character_set
  ncharacter_set = var.{{ db.module_name }}_ncharacter_set
{% if db.pdb_name %}
  pdb_name       = var.{{ db.module_name }}_pdb_name
{% endif %}
  auto_backup_enabled = var.{{ db.module_name }}_auto_backup_enabled
  depends_on     = [module.{{ db.module_name }}_dbhome]
}

{% if db.create_pdb and db.pdb_name %}
# ── OCI DB: {{ db.module_name }} — Step 3: PDB ───────────────────────────────
module "{{ db.module_name }}_pdb" {
  source                = "./modules/{{ db.module_name }}_pdb"
  container_database_id = module.{{ db.module_name }}_cdb.cdb_id
  pdb_name              = var.{{ db.module_name }}_pdb_name
  pdb_admin_password    = var.{{ db.module_name }}_admin_password
  depends_on            = [module.{{ db.module_name }}_cdb]
}
{% endif %}

variable "{{ db.module_name }}_db_home_display_name" { type = string; default = "{{ db.db_home_display_name }}" }
variable "{{ db.module_name }}_db_version"            { type = string; default = "{{ db.db_version }}" }
variable "{{ db.module_name }}_db_name"               { type = string; default = "{{ db.db_name }}" }
variable "{{ db.module_name }}_admin_password"        { type = string; sensitive = true }
variable "{{ db.module_name }}_character_set"         { type = string; default = "{{ db.character_set }}" }
variable "{{ db.module_name }}_ncharacter_set"        { type = string; default = "{{ db.ncharacter_set }}" }
{% if db.pdb_name %}
variable "{{ db.module_name }}_pdb_name"              { type = string; default = "{{ db.pdb_name }}" }
{% endif %}
variable "{{ db.module_name }}_auto_backup_enabled"   { type = bool;   default = {{ 'true' if db.auto_backup_enabled else 'false' }} }

output "{{ db.module_name }}_db_home_id" { value = module.{{ db.module_name }}_dbhome.db_home_id }
output "{{ db.module_name }}_cdb_id"     { value = module.{{ db.module_name }}_cdb.cdb_id }
{% if db.create_pdb and db.pdb_name %}
output "{{ db.module_name }}_pdb_id"     { value = module.{{ db.module_name }}_pdb.pdb_id }
{% endif %}

{% endfor %}
# ── Outputs ────────────────────────────────────────────────────────────────────
{% for net in networks %}
output "{{ net.module_name }}_network_id"  { value = module.{{ net.module_name }}.network_id }
output "{{ net.module_name }}_network_arn" { value = module.{{ net.module_name }}.network_arn }
{% endfor %}
{% for inf in infras %}
output "{{ inf.module_name }}_infra_id"  { value = module.{{ inf.module_name }}.infra_id }
output "{{ inf.module_name }}_infra_arn" { value = module.{{ inf.module_name }}.infra_arn }
{% endfor %}
{% for peer in peerings %}
output "{{ peer.module_name }}_peering_id" { value = module.{{ peer.module_name }}.peering_connection_id }
{% endfor %}
{% for cl in clusters %}
output "{{ cl.module_name }}_vm_cluster_id"   { value = module.{{ cl.module_name }}.vm_cluster_id }
output "{{ cl.module_name }}_vm_cluster_ocid" { value = module.{{ cl.module_name }}.ocid }
{% endfor %}
{% for av in avmclusters %}
output "{{ av.module_name }}_avmc_id"  { value = module.{{ av.module_name }}.avmc_id }
output "{{ av.module_name }}_avmc_arn" { value = module.{{ av.module_name }}.avmc_arn }
{% endfor %}
