# main.tf — Generated by Terraflow Studio
# Root module — wires all ODB@AWS modules.
# Toolchain: {{ 'OpenTofu' if iac_tool == 'opentofu' else 'Terraform' }}

terraform {
  required_version = "{{ '>= 1.6.0' if iac_tool == 'opentofu' else '>= 1.5.0' }}"
  required_providers {
    aws = {
{% if iac_tool == 'opentofu' %}
      # OpenTofu resolves hashicorp/aws from registry.opentofu.org by default
{% endif %}
      source  = "hashicorp/aws"
      version = ">= 6.15.0"
    }
{% if oci_databases %}
    oci = {
      source  = "oracle/oci"
      version = ">= 6.0.0"
    }
{% endif %}
  }
}

provider "aws" {
  region = var.aws_region
}

{% if oci_databases %}
# ── OCI Provider (DB Home / CDB / PDB) ───────────────────────────────────────
# Set these env vars or use a ~/.oci/config profile:
#   export TF_VAR_oci_tenancy_ocid=ocid1.tenancy...
#   export TF_VAR_oci_user_ocid=ocid1.user...
#   export TF_VAR_oci_fingerprint=xx:xx:xx:...
provider "oci" {
  auth             = var.oci_auth_method
  region           = var.oci_region
  tenancy_ocid     = var.oci_auth_method == "APIKey" ? var.oci_tenancy_ocid     : null
  user_ocid        = var.oci_auth_method == "APIKey" ? var.oci_user_ocid        : null
  fingerprint      = var.oci_auth_method == "APIKey" ? var.oci_fingerprint      : null
  private_key_path = var.oci_auth_method == "APIKey" ? var.oci_private_key_path : null
}
{% endif %}

{% for net in networks %}
# ── ODB Network: {{ net.module_name }} ──────────────────────────────────────────
module "{{ net.module_name }}" {
  source = "./modules/{{ net.module_name }}"
  tags   = var.tags
}

{% endfor %}
{% for inf in infras %}
# ── Exadata Infrastructure: {{ inf.module_name }} ──────────────────────────────
module "{{ inf.module_name }}" {
  source = "./modules/{{ inf.module_name }}"
  tags   = var.tags
}

{% endfor %}
{% for peer in peerings %}
# ── Network Peering: {{ peer.module_name }} ────────────────────────────────────
module "{{ peer.module_name }}" {
  source         = "./modules/{{ peer.module_name }}"
  odb_network_id = module.{{ peer.network_ref }}.network_id
  tags           = var.tags

  depends_on = [module.{{ peer.network_ref }}]
}

{% endfor %}
{% for cl in clusters %}
# ── VM Cluster: {{ cl.module_name }} ──────────────────────────────────────────
module "{{ cl.module_name }}" {
  source = "./modules/{{ cl.module_name }}"

  cloud_exadata_infrastructure_id = module.{{ cl.infra_ref }}.infra_id
  odb_network_id                  = module.{{ cl.network_ref }}.network_id
  tags                            = var.tags

  depends_on = [module.{{ cl.infra_ref }}, module.{{ cl.network_ref }}]
}

{% endfor %}
{% for av in avmclusters %}
# ── Autonomous VM Cluster: {{ av.module_name }} ───────────────────────────────
module "{{ av.module_name }}" {
  source = "./modules/{{ av.module_name }}"

  cloud_exadata_infrastructure_id  = module.{{ av.infra_ref }}.infra_id
  odb_network_id                   = module.{{ av.network_ref }}.network_id
  cloud_exadata_infrastructure_arn = module.{{ av.infra_ref }}.infra_arn
  odb_network_arn                  = module.{{ av.network_ref }}.network_arn
  tags                             = var.tags

  depends_on = [module.{{ av.infra_ref }}, module.{{ av.network_ref }}]
}

{% endfor %}
{% for db in oci_databases %}
# ── OCI DB: {{ db.module_name }} — Step 1: DB Home ───────────────────────────
module "{{ db.module_name }}_dbhome" {
  source          = "./modules/{{ db.module_name }}_dbhome"
  vm_cluster_ocid = module.{{ db.vmcluster_ref }}.ocid
  depends_on      = [module.{{ db.vmcluster_ref }}]
}

# ── OCI DB: {{ db.module_name }} — Step 2: CDB ───────────────────────────────
module "{{ db.module_name }}_cdb" {
  source         = "./modules/{{ db.module_name }}_cdb"
  db_home_id     = module.{{ db.module_name }}_dbhome.db_home_id
  admin_password = var.{{ db.module_name }}_admin_password
  depends_on     = [module.{{ db.module_name }}_dbhome]
}

{% if db.create_pdb and db.pdb_name %}
# ── OCI DB: {{ db.module_name }} — Step 3: PDB ───────────────────────────────
module "{{ db.module_name }}_pdb" {
  source                = "./modules/{{ db.module_name }}_pdb"
  container_database_id = module.{{ db.module_name }}_cdb.cdb_id
  pdb_admin_password    = var.{{ db.module_name }}_admin_password
  depends_on            = [module.{{ db.module_name }}_cdb]
}
{% endif %}

output "{{ db.module_name }}_db_home_id" { value = module.{{ db.module_name }}_dbhome.db_home_id }
output "{{ db.module_name }}_cdb_id"     { value = module.{{ db.module_name }}_cdb.cdb_id }
{% if db.create_pdb and db.pdb_name %}
output "{{ db.module_name }}_pdb_id" { value = module.{{ db.module_name }}_pdb.pdb_id }
{% endif %}

{% endfor %}
# ── Outputs ────────────────────────────────────────────────────────────────────
{% for net in networks %}
output "{{ net.module_name }}_network_id"  { value = module.{{ net.module_name }}.network_id }
output "{{ net.module_name }}_network_arn" { value = module.{{ net.module_name }}.network_arn }
{% endfor %}
{% for inf in infras %}
output "{{ inf.module_name }}_infra_id"  { value = module.{{ inf.module_name }}.infra_id }
output "{{ inf.module_name }}_infra_arn" { value = module.{{ inf.module_name }}.infra_arn }
{% endfor %}
{% for peer in peerings %}
output "{{ peer.module_name }}_peering_id" { value = module.{{ peer.module_name }}.peering_connection_id }
{% endfor %}
{% for cl in clusters %}
output "{{ cl.module_name }}_vm_cluster_id"   { value = module.{{ cl.module_name }}.vm_cluster_id }
output "{{ cl.module_name }}_vm_cluster_ocid" { value = module.{{ cl.module_name }}.ocid }
{% endfor %}
{% for av in avmclusters %}
output "{{ av.module_name }}_avmc_id"  { value = module.{{ av.module_name }}.avmc_id }
output "{{ av.module_name }}_avmc_arn" { value = module.{{ av.module_name }}.avmc_arn }
{% endfor %}
