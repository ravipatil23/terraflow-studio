# terraform.tfvars — Generated by Terraflow Studio

aws_region = "{{ aws_region }}"
{% for net in networks %}
# ── {{ net.module_name }} ──
{{ net.module_name }}_display_name         = "{{ net.display_name }}"
{{ net.module_name }}_availability_zone_id = "{{ net.availability_zone_id }}"
{{ net.module_name }}_client_subnet_cidr   = "{{ net.client_subnet_cidr }}"
{{ net.module_name }}_backup_subnet_cidr   = "{{ net.backup_subnet_cidr }}"
{{ net.module_name }}_s3_access            = "{{ net.s3_access }}"
{{ net.module_name }}_zero_etl_access      = "{{ net.zero_etl_access }}"
{% endfor %}
{% for inf in infras %}
# ── {{ inf.module_name }} ──
{{ inf.module_name }}_display_name         = "{{ inf.display_name }}"
{{ inf.module_name }}_shape                = "{{ inf.shape }}"
{{ inf.module_name }}_compute_count        = {{ inf.compute_count }}
{{ inf.module_name }}_storage_count        = {{ inf.storage_count }}
{{ inf.module_name }}_availability_zone_id = "{{ inf.availability_zone_id }}"
{% endfor %}
{% for peer in peerings %}
# ── {{ peer.module_name }} ──
{{ peer.module_name }}_display_name    = "{{ peer.display_name }}"
{{ peer.module_name }}_peer_network_id = "{{ peer.peer_network_id }}"
{% endfor %}
{% for cl in clusters %}
# ── {{ cl.module_name }} ──
{{ cl.module_name }}_display_name    = "{{ cl.display_name }}"
{{ cl.module_name }}_cpu_core_count  = {{ cl.cpu_core_count }}
{{ cl.module_name }}_gi_version      = "{{ cl.gi_version }}"
{{ cl.module_name }}_hostname_prefix = "{{ cl.hostname_prefix }}"
{{ cl.module_name }}_license_model   = "{{ cl.license_model }}"
{{ cl.module_name }}_ssh_public_keys = [{% for k in cl.ssh_public_keys %}"{{ k }}"{% if not loop.last %}, {% endif %}{% endfor %}]
{{ cl.module_name }}_db_servers      = []
{% endfor %}

{% for av in avmclusters %}
# ── {{ av.module_name }} ──
{{ av.module_name }}_display_name                          = "{{ av.display_name }}"
{{ av.module_name }}_autonomous_data_storage_size_in_tbs   = {{ av.autonomous_data_storage_size_in_tbs }}
{{ av.module_name }}_cpu_core_count_per_node               = {{ av.cpu_core_count_per_node }}
{{ av.module_name }}_memory_per_oracle_compute_unit_in_gbs = {{ av.memory_per_oracle_compute_unit_in_gbs }}
{{ av.module_name }}_total_container_databases             = {{ av.total_container_databases }}
{{ av.module_name }}_scan_listener_port_non_tls            = {{ av.scan_listener_port_non_tls }}
{{ av.module_name }}_scan_listener_port_tls                = {{ av.scan_listener_port_tls }}
{{ av.module_name }}_license_model                         = "{{ av.license_model }}"
{{ av.module_name }}_is_mtls_enabled_vm_cluster            = {{ av.is_mtls_enabled_vm_cluster }}
{{ av.module_name }}_db_servers                            = []
{% endfor %}

tags = {
{% for k, v in tags.items() %}
  "{{ k }}" = "{{ v }}"
{% else %}
  "ManagedBy" = "Terraform"
{% endfor %}
}
