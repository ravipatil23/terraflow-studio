# variables.tf — Generated by Terraflow Studio
# Root module variables — region, tags, and OCI provider config only.
# All module-specific variables (display_name, shape, etc.) live in each module's own variables.tf.

variable "aws_region" {
  type    = string
  default = "{{ aws_region }}"
}

variable "tags" {
  type    = map(string)
  default = {}
}

{% if oci_databases %}
# ── OCI provider ──────────────────────────────────────────────────────────────
variable "oci_auth_method" {
  type    = string
  default = "APIKey"
}
variable "oci_region" {
  type    = string
  default = "{{ oci_region }}"
}
variable "oci_tenancy_ocid" {
  type      = string
  default   = ""
  sensitive = true
}
variable "oci_user_ocid" {
  type      = string
  default   = ""
  sensitive = true
}
variable "oci_fingerprint" {
  type      = string
  default   = ""
  sensitive = true
}
variable "oci_private_key_path" {
  type    = string
  default = "~/.oci/oci_api_key.pem"
}

{% for db in oci_databases %}
# Set via: export TF_VAR_{{ db.module_name }}_admin_password=...
variable "{{ db.module_name }}_admin_password" {
  type      = string
  sensitive = true
}
{% endfor %}
{% endif %}
