# modules/{{ module_name }}/variables.tf

variable "display_name" {
  type = string
{% if display_name %}
  default = "{{ display_name }}"
{% endif %}
}

variable "cpu_core_count" {
  type    = number
  default = {{ cpu_core_count }}
}

variable "gi_version" {
  type = string
{% if gi_version %}
  default = "{{ gi_version }}"
{% endif %}
}

variable "hostname_prefix" {
  type = string
{% if hostname_prefix %}
  default = "{{ hostname_prefix }}"
{% endif %}
}

variable "license_model" {
  type    = string
  default = "{{ license_model }}"
  validation {
    condition     = contains(["LICENSE_INCLUDED", "BRING_YOUR_OWN_LICENSE"], var.license_model)
    error_message = "Must be LICENSE_INCLUDED or BRING_YOUR_OWN_LICENSE."
  }
}

# Infrastructure references — wired from module outputs in root main.tf:
{% if vm_mode == 'id' %}
#   cloud_exadata_infrastructure_id = module.{{ mn1 }}.infra_id
#   odb_network_id                  = module.{{ mn0 }}.network_id
variable "cloud_exadata_infrastructure_id" {
  description = "Exadata Infrastructure ID — auto-wired from module.{{ mn1 }}.infra_id in root."
  type    = string
  default = "{{ cloud_exadata_infrastructure_id }}"
}

variable "odb_network_id" {
  description = "ODB Network ID — auto-wired from module.{{ mn0 }}.network_id in root."
  type    = string
  default = "{{ odb_network_id }}"
}
{% else %}
#   cloud_exadata_infrastructure_arn = module.{{ mn1 }}.infra_arn
#   odb_network_arn                  = module.{{ mn0 }}.network_arn
variable "cloud_exadata_infrastructure_arn" {
  description = "Exadata Infrastructure ARN — auto-wired from module.{{ mn1 }}.infra_arn in root."
  type    = string
  default = "{{ cloud_exadata_infrastructure_arn }}"
}

variable "odb_network_arn" {
  description = "ODB Network ARN — auto-wired from module.{{ mn0 }}.network_arn in root."
  type    = string
  default = "{{ odb_network_arn }}"
}
{% endif %}

variable "ssh_public_keys" {
  description = "SSH public keys for cluster access."
  type        = list(string)
  default     = [{{ ssh_public_keys | map("tojson") | join(", ") }}]
}

{% if db_servers_mode == 'manual' %}
variable "db_servers" {
  description = "List of DB server IDs to place this VM Cluster on. Provided manually."
  type    = list(string)
  default = [{{ db_servers | map("tojson") | join(", ") }}]
}
{% else %}
# db_servers sourced from data.aws_odb_db_servers at plan time — no variable needed
{% endif %}

variable "dco_is_diagnostics_events_enabled" {
  type    = bool
  default = {{ dco_is_diagnostics_events_enabled }}
}

variable "dco_is_health_monitoring_enabled" {
  type    = bool
  default = {{ dco_is_health_monitoring_enabled }}
}

variable "dco_is_incident_logs_enabled" {
  type    = bool
  default = {{ dco_is_incident_logs_enabled }}
}

variable "cluster_name" {
  type    = string
  default = "{{ cluster_name }}"
}

variable "timezone" {
  type    = string
  default = "{{ timezone }}"
}

variable "data_storage_size_in_tbs" {
  type    = number
  default = {{ data_storage_size_in_tbs | default("null") }}
}

variable "db_node_storage_size_in_gbs" {
  type    = number
  default = {{ db_node_storage_size_in_gbs | default("null") }}
}

variable "memory_size_in_gbs" {
  type    = number
  default = {{ memory_size_in_gbs | default("null") }}
}

variable "scan_listener_port_tcp" {
  type    = number
  default = {{ scan_listener_port_tcp | default("null") }}
}

variable "system_version" {
  type    = string
  default = "{{ system_version }}"
}

variable "is_local_backup_enabled" {
  type    = bool
  default = {{ is_local_backup_enabled }}
}

variable "is_sparse_diskgroup_enabled" {
  type    = bool
  default = {{ is_sparse_diskgroup_enabled }}
}

variable "region" {
  type    = string
  default = "{{ region }}"
}

variable "tags" {
  type = map(string)
  default = {
{% for k, v in tags.items() %}
    "{{ k }}" = "{{ v }}"
{% else %}
    "ManagedBy" = "Terraform"
{% endfor %}
  }
}
