# modules/{{ module_name }}/main.tf
# Generated by Terraflow Studio

terraform {
  required_providers {
    google = {
      source  = "hashicorp/google"
      version = ">= 6.0.0"
    }
  }
}

resource "google_oracle_database_exadb_vm_cluster" "this" {
  exadb_vm_cluster_id = var.exadb_vm_cluster_id
  display_name        = var.display_name
  location            = var.location
  gcp_oracle_zone     = var.gcp_oracle_zone != "" ? var.gcp_oracle_zone : null
  odb_network         = var.odb_network
  odb_subnet          = var.odb_subnet
  backup_odb_subnet   = var.backup_odb_subnet
  project             = var.project != "" ? var.project : null
  deletion_protection = var.deletion_protection
  labels              = var.labels

  properties {
    gi_version                     = var.gi_version
    hostname_prefix                = var.hostname_prefix
    license_type                   = var.license_type
    node_count                     = var.node_count
    enabled_ecpu_count_per_node    = var.enabled_ecpu_count_per_node
    additional_ecpu_count_per_node = var.additional_ecpu_count_per_node
    ssh_public_keys                = var.ssh_public_keys

    cluster_name           = var.cluster_name != "" ? var.cluster_name : null
    time_zone              = var.time_zone != "" ? var.time_zone : null
    system_version         = var.system_version != "" ? var.system_version : null
    memory_per_node_in_gbs = var.memory_per_node_in_gbs != 0 ? var.memory_per_node_in_gbs : null

    db_node_storage_size_per_vm_in_gbs = var.db_node_storage_size_per_vm_in_gbs != 0 ? var.db_node_storage_size_per_vm_in_gbs : null
    data_storage_size_in_tbs           = var.data_storage_size_in_tbs != 0 ? var.data_storage_size_in_tbs : null
    spare_snapshot_space_in_gbs        = var.spare_snapshot_space_in_gbs != 0 ? var.spare_snapshot_space_in_gbs : null
    disk_redundancy                    = var.disk_redundancy != "" ? var.disk_redundancy : null
    exadata_infrastructure             = var.exadata_infrastructure != "" ? var.exadata_infrastructure : null

    vm_file_system_storage {
      size_in_gbs_per_node = var.vm_file_system_storage_size_gbs
    }

{% if db_servers %}
{% for ocid in db_servers %}
    db_servers {
      ocid = "{{ ocid }}"
    }
{% endfor %}
{% endif %}

    data_collection_options {
      diagnostics_events_enabled = var.dco_diagnostics
      health_monitoring_enabled  = var.dco_health
      incident_logs_enabled      = var.dco_incident_logs
    }
  }
}
