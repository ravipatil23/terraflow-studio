# modules/{{ module_name }}/variables.tf

variable "odb_network_id" {
  description = "The ID of the ODB Network. Must start with a letter, max 63 chars."
  type        = string
{% if odb_network_id %}
  default     = "{{ odb_network_id }}"
{% endif %}
}

variable "location" {
  description = "GCP region where the ODB Network is hosted (e.g. us-east4)."
  type        = string
{% if location %}
  default     = "{{ location }}"
{% endif %}
}

variable "network" {
  description = "VPC network self-link. Format: projects/{project}/global/networks/{name}"
  type        = string
{% if network %}
  default     = "{{ network }}"
{% endif %}
}

variable "project" {
  type    = string
  default = "{{ project }}"
}

variable "gcp_oracle_zone" {
  type    = string
  default = "{{ gcp_oracle_zone }}"
}

variable "deletion_protection" {
  type    = bool
  default = {{ deletion_protection }}
}

variable "labels" {
  type = map(string)
  default = {
{% for k, v in labels.items() %}
    "{{ k }}" = "{{ v }}"
{% else %}
    "managed-by" = "terraform"
{% endfor %}
  }
}
