# main.tf — Generated by Terraflow Studio
# DB@GCP: ODB Networks → Subnets → Exadata Infras → ExaDB VM Clusters
# Toolchain: {{ 'OpenTofu' if iac_tool == 'opentofu' else 'Terraform' }}

terraform {
  required_version = "{{ '>= 1.6.0' if iac_tool == 'opentofu' else '>= 1.5.0' }}"
  required_providers {
    google = {
{% if iac_tool == 'opentofu' %}
      # OpenTofu resolves hashicorp/google from registry.opentofu.org by default
{% endif %}
      source  = "hashicorp/google"
      version = ">= 6.0.0"
    }
  }
}

provider "google" {
  project = var.gcp_project
  region  = var.gcp_region
}

{% for net in networks %}
# ── ODB Network: {{ net.module_name }} ──────────────────────────────────────────
module "{{ net.module_name }}" {
  source = "./modules/{{ net.module_name }}"

  odb_network_id = var.{{ net.module_name }}_odb_network_id
  location       = var.gcp_region
  network        = var.{{ net.module_name }}_vpc_self_link
  project        = var.gcp_project
  labels         = var.labels
}

# ── Client Subnet: {{ net.client_subnet_module }} ──
module "{{ net.client_subnet_module }}" {
  source = "./modules/{{ net.client_subnet_module }}"

  odb_subnet_id = var.{{ net.client_subnet_module }}_id
  location      = var.gcp_region
  odb_network   = module.{{ net.module_name }}.odb_network_id
  cidr_range    = var.{{ net.client_subnet_module }}_cidr
  purpose       = "CLIENT_SUBNET"
  project       = var.gcp_project

  depends_on = [module.{{ net.module_name }}]
}

# ── Backup Subnet: {{ net.backup_subnet_module }} ──
module "{{ net.backup_subnet_module }}" {
  source = "./modules/{{ net.backup_subnet_module }}"

  odb_subnet_id = var.{{ net.backup_subnet_module }}_id
  location      = var.gcp_region
  odb_network   = module.{{ net.module_name }}.odb_network_id
  cidr_range    = var.{{ net.backup_subnet_module }}_cidr
  purpose       = "BACKUP_SUBNET"
  project       = var.gcp_project

  depends_on = [module.{{ net.module_name }}]
}

{% endfor %}
{% for inf in infras %}
# ── Exadata Infrastructure: {{ inf.module_name }} ──────────────────────────────
module "{{ inf.module_name }}" {
  source = "./modules/{{ inf.module_name }}"

  cloud_exadata_infrastructure_id = var.{{ inf.module_name }}_infra_id
  display_name                    = var.{{ inf.module_name }}_display_name
  location                        = var.gcp_region
  gcp_oracle_zone                 = var.{{ inf.module_name }}_gcp_oracle_zone
  project                         = var.gcp_project
  shape                           = var.{{ inf.module_name }}_shape
  compute_count                   = var.{{ inf.module_name }}_compute_count
  storage_count                   = var.{{ inf.module_name }}_storage_count
  labels                          = var.labels
}

{% endfor %}
{% for cl in clusters %}
# ── ExaDB VM Cluster: {{ cl.module_name }} ────────────────────────────────────
module "{{ cl.module_name }}" {
  source = "./modules/{{ cl.module_name }}"

  exadb_vm_cluster_id         = var.{{ cl.module_name }}_cluster_id
  display_name                = var.{{ cl.module_name }}_display_name
  location                    = var.gcp_region
  gcp_oracle_zone             = var.{{ cl.module_name }}_gcp_oracle_zone
  odb_network                 = module.{{ cl.network_ref }}.odb_network_name
  odb_subnet                  = module.{{ cl.client_subnet_ref }}.odb_subnet_name
  backup_odb_subnet           = module.{{ cl.backup_subnet_ref }}.odb_subnet_name
  project                     = var.gcp_project
  gi_version                  = var.{{ cl.module_name }}_gi_version
  hostname_prefix             = var.{{ cl.module_name }}_hostname_prefix
  license_type                = var.{{ cl.module_name }}_license_type
  node_count                  = var.{{ cl.module_name }}_node_count
  enabled_ecpu_count_per_node = var.{{ cl.module_name }}_enabled_ecpu_count_per_node
  ssh_public_keys             = var.{{ cl.module_name }}_ssh_public_keys
  exadata_infrastructure      = module.{{ cl.infra_ref }}.infra_name
  labels                      = var.labels

  depends_on = [module.{{ cl.network_ref }}, module.{{ cl.client_subnet_ref }},
                module.{{ cl.backup_subnet_ref }}, module.{{ cl.infra_ref }}]
}

{% endfor %}
# ── Outputs ────────────────────────────────────────────────────────────────────
{% for net in networks %}
output "{{ net.module_name }}_odb_network_name"   { value = module.{{ net.module_name }}.odb_network_name }
output "{{ net.client_subnet_module }}_name"      { value = module.{{ net.client_subnet_module }}.odb_subnet_name }
output "{{ net.backup_subnet_module }}_name"      { value = module.{{ net.backup_subnet_module }}.odb_subnet_name }
{% endfor %}
{% for inf in infras %}
output "{{ inf.module_name }}_infra_name"         { value = module.{{ inf.module_name }}.infra_name }
{% endfor %}
{% for cl in clusters %}
output "{{ cl.module_name }}_vm_cluster_name"     { value = module.{{ cl.module_name }}.vm_cluster_name }
{% endfor %}
