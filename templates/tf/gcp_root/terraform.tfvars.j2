# terraform.tfvars — Generated by Terraflow Studio

gcp_project = "{{ gcp_project }}"
gcp_region  = "{{ gcp_region }}"
{% for net in networks %}
# ── {{ net.module_name }} ──
{{ net.module_name }}_odb_network_id = "{{ net.odb_network_id }}"
{{ net.module_name }}_vpc_self_link  = "{{ net.network }}"
{{ net.client_subnet_module }}_id   = "{{ net.client_subnet_id }}"
{{ net.client_subnet_module }}_cidr = "{{ net.client_cidr }}"
{{ net.backup_subnet_module }}_id   = "{{ net.backup_subnet_id }}"
{{ net.backup_subnet_module }}_cidr = "{{ net.backup_cidr }}"
{% endfor %}
{% for inf in infras %}
# ── {{ inf.module_name }} ──
{{ inf.module_name }}_infra_id       = "{{ inf.cloud_exadata_infrastructure_id }}"
{{ inf.module_name }}_display_name   = "{{ inf.display_name }}"
{{ inf.module_name }}_gcp_oracle_zone = "{{ inf.gcp_oracle_zone }}"
{{ inf.module_name }}_shape          = "{{ inf.shape }}"
{{ inf.module_name }}_compute_count  = {{ inf.compute_count }}
{{ inf.module_name }}_storage_count  = {{ inf.storage_count }}
{% endfor %}
{% for cl in clusters %}
# ── {{ cl.module_name }} ──
{{ cl.module_name }}_cluster_id                  = "{{ cl.exadb_vm_cluster_id }}"
{{ cl.module_name }}_display_name                = "{{ cl.display_name }}"
{{ cl.module_name }}_gcp_oracle_zone             = "{{ cl.gcp_oracle_zone }}"
{{ cl.module_name }}_gi_version                  = "{{ cl.gi_version }}"
{{ cl.module_name }}_hostname_prefix             = "{{ cl.hostname_prefix }}"
{{ cl.module_name }}_license_type                = "{{ cl.license_type }}"
{{ cl.module_name }}_node_count                  = {{ cl.node_count }}
{{ cl.module_name }}_enabled_ecpu_count_per_node = {{ cl.enabled_ecpu_count_per_node }}
{{ cl.module_name }}_ssh_public_keys             = [{% for k in cl.ssh_public_keys %}"{{ k }}"{% if not loop.last %}, {% endif %}{% endfor %}]
{% endfor %}

labels = {
{% for k, v in labels.items() %}
  "{{ k }}" = "{{ v }}"
{% else %}
  "managed-by" = "terraform"
{% endfor %}
}
