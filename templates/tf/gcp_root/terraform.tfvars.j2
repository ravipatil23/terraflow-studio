# terraform.tfvars — Generated by Terraflow Studio
# Module-specific variables (IDs, display names, shapes, etc.) are pre-set as
# defaults in each module's own variables.tf — override there or via -var flags.

gcp_project = "{{ gcp_project }}"
gcp_region  = "{{ gcp_region }}"

labels = {
{% for k, v in labels.items() %}
  "{{ k }}" = "{{ v }}"
{% else %}
  "managed-by" = "terraform"
{% endfor %}
}
